    {
      "description": "a request to list transactions with default pagination",
      "providerStates": [
        {
          "name": "the authenticated user has at least one transaction"
        }
      ],
      "request": {
        "headers": {
          "Authorization": "Bearer test-jwt-token"
        },
        "matchingRules": {
          "header": {
            "Authorization": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "GET",
        "path": "/api/transactions",
        "query": {
          "limit": ["10"],
          "page": ["1"]
        }
      },
      "response": {
        "body": {
          "data": [
            {
              "amount": 5000,
              "created_at": "2026-06-25T08:00:00.000Z",
              "currency": "XAF",
              "id": "txn-uuid-001",
              "status": "completed"
            }
          ],
          "pagination": {
            "limit": 10,
            "page": 1,
            "total": 1
          }
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.data": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data[*].amount": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data[*].created_at": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data[*].currency": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data[*].id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data[*].status": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.pagination.limit": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$.pagination.page": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$.pagination.total": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
