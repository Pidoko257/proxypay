{
  "consumer": {
    "name": "proxypay-frontend"
  },
  "interactions": [
    {
      "description": "a health check request",
      "providerStates": [
        {
          "name": "the API is running"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/health"
      },
      "response": {
        "body": {
          "status": "ok",
          "timestamp": "2026-06-25T08:00:00.000Z"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.status": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.timestamp": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a login request with invalid credentials",
      "providerStates": [
        {
          "name": "no user exists with phone +237670000099"
        }
      ],
      "request": {
        "body": {
          "password": "WrongPassword1!",
          "phone_number": "+237670000099"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.password": {
              "combine": "AND",
