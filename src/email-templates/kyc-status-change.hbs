<h1 style="margin:0 0 16px;font-size:24px;font-weight:bold;color:#111827;">KYC Verification Update</h1>
<p style="margin:0 0 20px;font-size:15px;color:#374151;line-height:1.6;">
  Hi {{firstName}}, your identity verification status has been updated.
</p>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:0 0 24px;">
  <tr>
    <td style="padding:20px;border-radius:6px;background-color:{{statusBg}};border-left:4px solid {{statusBorder}};">
      <p style="margin:0 0 4px;font-size:13px;font-weight:bold;color:#6b7280;text-transform:uppercase;letter-spacing:0.5px;">Status</p>
      <p style="margin:0;font-size:20px;font-weight:bold;color:{{statusColor}};">{{statusLabel}}</p>
    </td>
  </tr>
</table>
{{#if message}}
<p style="margin:0 0 20px;font-size:15px;color:#374151;line-height:1.6;">{{message}}</p>
{{/if}}
{{#if nextSteps}}
<p style="margin:0 0 8px;font-size:14px;font-weight:bold;color:#111827;">Next steps:</p>
<p style="margin:0 0 24px;font-size:14px;color:#374151;line-height:1.6;">{{nextSteps}}</p>
{{/if}}
{{#if actionUrl}}
<table role="presentation" cellpadding="0" cellspacing="0" border="0">
  <tr>
    <td style="border-radius:6px;background-color:#1a56db;">
      <a href="{{actionUrl}}" style="display:inline-block;padding:12px 28px;font-size:15px;font-weight:bold;color:#ffffff;text-decoration:none;">{{actionLabel}}</a>
    </td>
  </tr>
</table>
{{/if}}
