<h1 style="margin:0 0 16px;font-size:24px;font-weight:bold;color:#111827;">Transaction Failed</h1>
<p style="margin:0 0 20px;font-size:15px;color:#374151;line-height:1.6;">
  Unfortunately, your {{typeLocalized}} transaction could not be completed.
</p>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:0 0 24px;background-color:#fef2f2;border:1px solid #fca5a5;border-radius:6px;">
  <tr>
    <td style="padding:16px 20px;">
      <p style="margin:0 0 4px;font-size:13px;font-weight:bold;color:#991b1b;text-transform:uppercase;letter-spacing:0.5px;">Reason</p>
      <p style="margin:0;font-size:15px;color:#374151;">{{reason}}</p>
    </td>
  </tr>
</table>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:0 0 24px;border:1px solid #e5e7eb;border-radius:6px;border-collapse:separate;">
  <tr>
    <td style="padding:10px 20px;font-size:14px;color:#6b7280;border-bottom:1px solid #f3f4f6;">Reference</td>
    <td style="padding:10px 20px;font-size:14px;color:#111827;text-align:right;font-family:monospace;border-bottom:1px solid #f3f4f6;">{{referenceNumber}}</td>
  </tr>
  <tr>
    <td style="padding:10px 20px;font-size:14px;color:#6b7280;border-bottom:1px solid #f3f4f6;">Amount</td>
    <td style="padding:10px 20px;font-size:14px;color:#111827;text-align:right;border-bottom:1px solid #f3f4f6;">{{amount}}</td>
  </tr>
  {{#if merchantDisplayName}}
  <tr>
    <td style="padding:10px 20px;font-size:14px;color:#6b7280;border-bottom:1px solid #f3f4f6;">Merchant</td>
    <td style="padding:10px 20px;font-size:14px;color:#111827;text-align:right;border-bottom:1px solid #f3f4f6;">{{merchantDisplayName}}</td>
  </tr>
  {{/if}}
  <tr>
    <td style="padding:10px 20px;font-size:14px;color:#6b7280;">Type</td>
    <td style="padding:10px 20px;font-size:14px;color:#111827;text-align:right;">{{typeLocalized}}</td>
  </tr>
</table>
<p style="margin:0;font-size:13px;color:#6b7280;">No funds have been deducted. If you believe this is an error, please contact support.</p>
