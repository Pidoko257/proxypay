<h1 style="margin:0 0 16px;font-size:24px;font-weight:bold;color:#111827;">Transaction Receipt</h1>
<p style="margin:0 0 20px;font-size:15px;color:#374151;line-height:1.6;">
  Your {{typeLocalized}} transaction has completed successfully.
</p>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:0 0 24px;border:1px solid #e5e7eb;border-radius:6px;border-collapse:separate;">
  <tr style="background-color:#f9fafb;">
    <td colspan="2" style="padding:12px 20px;font-size:13px;font-weight:bold;color:#6b7280;border-bottom:1px solid #e5e7eb;">RECEIPT</td>
  </tr>
  <tr>
    <td style="padding:10px 20px;font-size:14px;color:#6b7280;border-bottom:1px solid #f3f4f6;">Reference</td>
    <td style="padding:10px 20px;font-size:14px;color:#111827;text-align:right;font-family:monospace;border-bottom:1px solid #f3f4f6;">{{referenceNumber}}</td>
  </tr>
  <tr>
    <td style="padding:10px 20px;font-size:14px;color:#6b7280;border-bottom:1px solid #f3f4f6;">Amount</td>
    <td style="padding:10px 20px;font-size:18px;font-weight:bold;color:#059669;text-align:right;border-bottom:1px solid #f3f4f6;">{{amount}}</td>
  </tr>
  <tr>
    <td style="padding:10px 20px;font-size:14px;color:#6b7280;border-bottom:1px solid #f3f4f6;">Provider</td>
    <td style="padding:10px 20px;font-size:14px;color:#111827;text-align:right;border-bottom:1px solid #f3f4f6;">{{provider}}</td>
  </tr>
  <tr>
    <td style="padding:10px 20px;font-size:14px;color:#6b7280;border-bottom:1px solid #f3f4f6;">Phone</td>
    <td style="padding:10px 20px;font-size:14px;color:#111827;text-align:right;border-bottom:1px solid #f3f4f6;">{{phoneNumber}}</td>
  </tr>
  {{#if merchantDisplayName}}
  <tr>
    <td style="padding:10px 20px;font-size:14px;color:#6b7280;border-bottom:1px solid #f3f4f6;">Merchant</td>
    <td style="padding:10px 20px;font-size:14px;color:#111827;text-align:right;border-bottom:1px solid #f3f4f6;">{{merchantDisplayName}}</td>
  </tr>
  {{/if}}
  <tr>
    <td style="padding:10px 20px;font-size:14px;color:#6b7280;">Date</td>
    <td style="padding:10px 20px;font-size:14px;color:#111827;text-align:right;">{{createdAt}}</td>
  </tr>
</table>
{{#if stellarExpertUrl}}
<p style="margin:0;font-size:13px;color:#6b7280;">
  View on Stellar: <a href="{{stellarExpertUrl}}" style="color:#1a56db;">{{transactionHash}}</a>
</p>
{{/if}}
